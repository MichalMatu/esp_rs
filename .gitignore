!.env.example
secrets.*
*.pem
*.key
*.crt

# VS Code: ignore local state, keep useful shared project config
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json
*.code-workspace

# Temporary files
*.tmp
*.swp
*.swo
*~
